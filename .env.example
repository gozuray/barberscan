# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Local-dev toggles (OFF in production) ─────────────
# When LOCAL_DEV_NO_AUTH=true:
#   - Clerk is bypassed completely
#   - Middleware stops protecting any route
#   - A single "Local Dev" user is auto-created on first /dashboard visit
#   - The new-analysis form shows a "paste image URL" fallback so you
#     don't need UploadThing to test.
# When AI_USE_CUSTOM_PROMPT=true:
#   - The analysis pipeline skips face-analysis + 8-style loop and sends
#     exactly one prompt (see src/lib/ai/custom-prompt.ts) to the active
#     AI provider. The generated image shows up in the client's gallery.
LOCAL_DEV_NO_AUTH=false
AI_USE_CUSTOM_PROMPT=false

# ─── Database (PostgreSQL) ─────────────────────────────
# Prisma CLI (`npm run db:push`) loads `.env` by default — duplicate these two
# lines into a root `.env` file (gitignored), or use Docker: `npm run db:up`
# then URLs like postgresql://barberscan:barberscan@localhost:5432/barberscan
DATABASE_URL="postgresql://user:password@localhost:5432/barberscan?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/barberscan?schema=public"

# ─── Auth (Clerk) ──────────────────────────────────────
# Optional: in Clerk → Configure → User & authentication → Social connections,
# enable "Google" and "Sign in with Apple" (Apple needs Apple Developer setup in Clerk).
# The sign-in / sign-up pages show those buttons when enabled; no extra env keys here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create products in dashboard first)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_STUDIO_MONTHLY=price_xxx
STRIPE_PRICE_STUDIO_YEARLY=price_xxx

# ─── AI provider routing ───────────────────────────────
# Default engine used when a request does not specify one.
# Valid values: nanobanana | openai
AI_PROVIDER=nanobanana

# ─── NanoBananaPRO ─────────────────────────────────────
NANOBANANA_API_KEY=sk_xxx
NANOBANANA_BASE_URL=https://gateway.bananapro.site/api
# If NANOBANANA_API_KEY is a Google key (AIza…), use Gemini image models instead:
# NANOBANANA_MODEL=gemini-3-pro-image-preview
# NANOBANANA_GEMINI_IMAGE_SIZE=2K   # 512 | 1K | 2K | 4K
NANOBANANA_TIMEOUT_MS=120000

# ─── OpenAI (ChatGPT 5.5 + image model) ────────────────
# Required only if you want to A/B test against NanoBananaPRO.
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=90000
OPENAI_ANALYSIS_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1

# ─── Storage (UploadThing) ─────────────────────────────
UPLOADTHING_TOKEN=eyJxxx
UPLOADTHING_SECRET=sk_live_xxx

# ─── Rate Limiting / Cache (Upstash Redis) ─────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
